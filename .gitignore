# Rider
.idea/
*.sln.DotSettings.user

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# OS generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Unity crash reports
sysinfo.txt

# Unity Addressables
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Builds
*.apk
*.aab
*.unitypackage

# Logs
*.log

# Local environment
.env
